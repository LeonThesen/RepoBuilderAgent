# Base Dockerfile projects
# Includes: Debian, CA bootstrap, git, curl, pkg-config, Python venv on PATH

# Pinned by digest so the base layer is frozen: debian:forky-slim is a rolling
# testing tag that gets re-published, which would silently change the base
# between eval runs and break reproducibility. Re-pin with:
#   docker pull debian:forky-slim && docker inspect debian:forky-slim --format '{{index .RepoDigests 0}}'
# (NOTE: the forky apt repos still roll; the digest only freezes the base image.)
FROM debian:forky-slim@sha256:484c506e686dd6a8e2977a16d2fbab99763486c1c05f93e1dd29e6a26efe6e03

# Non-interactive apt so `sudo apt-get install` never blocks on a prompt.
ENV DEBIAN_FRONTEND=noninteractive

# Make builds (as) reproducible (as possible)
ENV SOURCE_DATE_EPOCH=0
ENV CARGO_INCREMENTAL=0
ENV RUSTFLAGS="-C codegen-units=1"

# Skip Playwright browser-binary downloads during `npm/pnpm install`. A repo with
# Playwright in its dev dependency tree (e.g. vite) runs a postinstall that downloads
# 170 MiB+ of browsers and then a launch-validation that hangs indefinitely in a
# minimal container missing libnss3/libnspr4 — this stalled vite's build until the
# build timeout killed it. Browsers are irrelevant to building a package, so skip them.
# Harmless no-op for repos that do not use Playwright.
ENV PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1

# Install CA certificates and corporate CA if provided
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Decode and install corporate CA if present
RUN if [ -n "$MANUALREPOS_CA_CERT_B64" ]; then \
      echo "$MANUALREPOS_CA_CERT_B64" | base64 -d > /usr/local/share/ca-certificates/corporate-ca.crt && \
      update-ca-certificates; \
    fi

# Install default packages (incl. sudo, so the build user can install system packages;
# xxhash provides xxh64sum, used post-build to hash artifacts for HARD verification).
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    git \
    curl \
    pkg-config \
    sudo \
    xxhash \
    python3 \
    python3-venv \
    && rm -rf /var/lib/apt/lists/*

# Non-root build user with passwordless sudo, so the build feels like a normal dev
# environment: build commands run as this user; use `sudo` for system package installs
# (`sudo apt-get install ...`) or privileged steps (`sudo make install`). The repo
# directory is owned by the user so the build can write artifacts into it.
#
# env_keep: sudo's default env_reset strips the corporate-CA trust env vars
# (NODE_*, *_CA_*, SSL_CERT_*) that the auto-injected CA bootstrap exports. Without
# this, `sudo npm install -g ...` / `sudo pip install ...` / `sudo cargo ...` run with
# default-strict TLS behind the corporate intercepting proxy and fail with
# "self-signed certificate in certificate chain". Preserving these vars across sudo
# makes privileged installs trust the same CA as the non-root user. Generic to any
# repo that installs packages via sudo; harmless otherwise.
RUN useradd -m -s /bin/bash manualrepos \
    && mkdir -p /home/manualrepos/repo \
    && chown manualrepos:manualrepos /home/manualrepos/repo \
    && printf '%s\n' \
        'manualrepos ALL=(ALL) NOPASSWD:ALL' \
        'Defaults env_keep += "SSL_CERT_FILE SSL_CERT_DIR REQUESTS_CA_BUNDLE CURL_CA_BUNDLE NODE_EXTRA_CA_CERTS NODE_TLS_REJECT_UNAUTHORIZED CARGO_HTTP_CAINFO JAVA_TOOL_OPTIONS GRADLE_OPTS MAVEN_OPTS"' \
        > /etc/sudoers.d/manualrepos \
    && chmod 0440 /etc/sudoers.d/manualrepos

# Pre-provision a Python virtualenv on PATH. Debian's system Python is marked
# externally-managed (PEP 668), so a bare `pip install` fails with
# "error: externally-managed-environment"; build front-ends (meson-python, build,
# scikit-build) and the agent then need venv/--break-system-packages boilerplate just to
# install build deps. Shipping an activated venv means `pip install ...` and `pip install -U`
# (e.g. bumping cython/meson past the stale distro versions) work directly. It also puts
# `python`/`pip` on PATH so tools that shell out to bare `python` resolve. Owned by the
# build user so non-root installs write without sudo. Inert for non-Python repos.
RUN python3 -m venv /opt/venv \
    && chown -R manualrepos:manualrepos /opt/venv
ENV VIRTUAL_ENV="/opt/venv"
ENV PATH="/opt/venv/bin:$PATH"

# Pre-provision OpenJDK 21 (current LTS) on PATH. This works around a forky-specific
# vice for JVM builds: the base's apt repos have DROPPED older versioned packages
# (openjdk-11/17-jdk fail with "Unable to locate package"), while the `default-jdk`
# meta-package now resolves to the newest JDK (java-25), which Gradle/Maven builds
# that pin a toolchain `languageVersion` in a bounded range (e.g. [17,22)) REJECT as
# too new. openjdk-21-jdk is the one apt package that is both still present AND an
# in-range LTS, so shipping it in the base means JVM builds neither guess a dropped
# version nor land on a too-new default. JAVA_HOME is set so tools/Gradle resolve it
# without hardcoding a version-specific path. Inert for non-Java repos (only disk).
RUN apt-get update && apt-get install -y --no-install-recommends \
    openjdk-21-jdk \
    && rm -rf /var/lib/apt/lists/*
ENV JAVA_HOME="/usr/lib/jvm/java-21-openjdk-amd64"
ENV PATH="$JAVA_HOME/bin:$PATH"
USER manualrepos
WORKDIR /home/manualrepos/repo

# Copy repository from build context (already checked out on host)
COPY --chown=manualrepos:manualrepos . .

# Dependency installs + build commands go here. EACH step is a Docker RUN instruction
# (every line starts with RUN), running as the non-root user which has passwordless sudo.
# Edit only between the markers. Example:
#   RUN sudo apt-get update && sudo apt-get install -y cargo rustc
#   RUN cargo build --release
# AGENT_BUILD_STEPS_BEGIN
# [PLACEHOLDER: RUN <dependency installs>, then RUN <build commands>]
# AGENT_BUILD_STEPS_END

# Final CMD or ENTRYPOINT (runs as manualrepos)
# [PLACEHOLDER: Binary path or entry point]
