# Base Dockerfile for Rust projects
# Includes: Debian, CA bootstrap, rustup, cargo, build-essential

FROM debian:forky-slim

# Install CA certificates and corporate CA if provided
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Decode and install corporate CA if present
RUN if [ -n "$MANUALREPOS_CA_CERT_B64" ]; then \
      echo "$MANUALREPOS_CA_CERT_B64" | base64 -d > /usr/local/share/ca-certificates/corporate-ca.crt && \
      update-ca-certificates; \
    fi

# Install base build tools before Rust (curl is needed for rustup)
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    curl \
    git \
    pkg-config \
    libssl-dev \
    && rm -rf /var/lib/apt/lists/*

# Create non-root user and install Rust
RUN useradd -m -s /bin/bash manualrepos
USER manualrepos
WORKDIR /home/manualrepos/repo

# Install Rust via rustup (will use system CA bundle after bootstrap above)
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y

# Add Rust binaries to PATH
ENV PATH="/home/manualrepos/.cargo/bin:${PATH}"

# Copy repository from build context (already checked out on host)
COPY . .
RUN chown -R manualrepos:manualrepos /home/manualrepos/repo

# Build instructions
# [PLACEHOLDER: cargo build --release or cargo build steps]

