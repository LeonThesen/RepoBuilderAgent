# Base Dockerfile for Java projects
# Includes: Debian, CA bootstrap, OpenJDK JDK, Maven, Gradle wrapper support

FROM debian:forky-slim

# Install CA certificates and corporate CA if provided
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Decode and install corporate CA if present
RUN if [ -n "$MANUALREPOS_CA_CERT_B64" ]; then \
      echo "$MANUALREPOS_CA_CERT_B64" | base64 -d > /usr/local/share/ca-certificates/corporate-ca.crt && \
      update-ca-certificates; \
    fi

# Install Java JDK and build tools
RUN apt-get update && apt-get install -y --no-install-recommends \
    openjdk-21-jdk-headless \
    maven \
    curl \
    git \
    && rm -rf /var/lib/apt/lists/*

# Create non-root user
RUN useradd -m -s /bin/bash manualrepos
WORKDIR /home/manualrepos/repo

# Set JAVA_HOME for Maven/Gradle
ENV JAVA_HOME=/usr/lib/jvm/java-21-openjdk-amd64
ENV PATH="${JAVA_HOME}/bin:${PATH}"

# Copy repository from build context (already checked out on host)
COPY . .
RUN chown -R manualrepos:manualrepos /home/manualrepos/repo

# Maven/Gradle build instructions
# [PLACEHOLDER: mvn clean package or gradle build based on repo configuration]

# Final CMD or ENTRYPOINT
# [PLACEHOLDER: java -jar target/app.jar or equivalent entry point]
