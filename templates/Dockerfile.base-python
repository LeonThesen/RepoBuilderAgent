# Base Dockerfile for Python projects
# Includes: Debian, CA bootstrap, Python 3, venv, pip, build-essential

FROM debian:forky-slim

# Install CA certificates and corporate CA if provided
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Decode and install corporate CA if present
RUN if [ -n "$MANUALREPOS_CA_CERT_B64" ]; then \
      echo "$MANUALREPOS_CA_CERT_B64" | base64 -d > /usr/local/share/ca-certificates/corporate-ca.crt && \
      update-ca-certificates; \
    fi

# Install Python and build tools
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 \
    python3-venv \
    python3-pip \
    build-essential \
    git \
    pkg-config \
    && rm -rf /var/lib/apt/lists/*

# Create non-root user
RUN useradd -m -s /bin/bash manualrepos
WORKDIR /home/manualrepos/repo

# Copy repository from build context (already checked out on host)
COPY . .
RUN chown -R manualrepos:manualrepos /home/manualrepos/repo

# Create and activate venv, install dependencies
# [PLACEHOLDER: python3 -m venv /home/manualrepos/venv && source /home/manualrepos/venv/bin/activate && pip install -r requirements.txt]

